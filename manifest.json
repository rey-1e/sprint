{
  "manifest_version": 3,
  "name": "CodeSprint - AI Companion for Programmers",
  "version": "3.2.3",
  "description": "Site-Specific Customizations, Analyze complexities, AI Debugging, AI Assistant Tailored for Programmers",
  "icons": {
    "128": "icon.png",
    "192": "icon.png",
    "512": "icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Sprint Assistant"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://us-central1-sprint-87863.cloudfunctions.net/*",
    "https://*.a.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "https://getsprint.me/*",
        "https://*.getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content/leetcode/leetcode-start.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://codeforces.com/*",
        "https://*.codeforces.com/*"
      ],
      "js": [
        "content/codeforces/codeforces-start.js"
      ],
      "css": [
        "styles/codeforces/codeforces.css",
        "styles/codeforces/codeforces-themes.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/content-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/leetcode/leetcode-idle.js"
      ],
      "css": [
        "styles/leetcode/leetcode.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "https://getsprint.me/*",
        "https://*.getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "*://*.github.com/*",
        "*://*.github.io/*",
        "*://*.gitlab.com/*",
        "*://*.bitbucket.org/*",
        "*://*.gitee.com/*",
        "*://*.codeforces.com/*",
        "*://*.codeforces.ru/*",
        "*://*.atcoder.jp/*",
        "*://*.codechef.com/*",
        "*://*.hackerearth.com/*",
        "*://*.hackerrank.com/*",
        "*://*.topcoder.com/*",
        "*://*.geeksforgeeks.org/*",
        "*://*.stackoverflow.com/*",
        "*://*.stackexchange.com/*",
        "*://*.codewars.com/*",
        "*://*.coderbyte.com/*",
        "*://*.projecteuler.net/*",
        "*://*.spoj.com/*",
        "*://*.vjudge.net/*",
        "*://*.dmoj.ca/*",
        "*://*.oj.uz/*",
        "*://*.replit.com/*",
        "*://*.replit.co/*",
        "*://*.repl.it/*",
        "*://*.glot.io/*",
        "*://*.ideone.com/*",
        "*://*.jdoodle.com/*",
        "*://*.onlinegdb.com/*",
        "*://*.codepen.io/*",
        "*://*.jsfiddle.net/*",
        "*://*.scrimba.com/*",
        "*://*.freecodecamp.org/*",
        "*://*.w3schools.com/*",
        "*://*.programiz.com/*",
        "*://*.codecademy.com/*",
        "*://*.apnacollege.in/*",
        "*://*.apnacollege.com/*",
        "*://*.interviewbit.com/*",
        "*://*.lintcode.com/*",
        "*://*.algoexpert.io/*",
        "*://*.exercism.org/*",
        "*://*.exercism.io/*",
        "*://*.cses.fi/*",
        "*://*.hackerone.com/*",
        "*://*.luogu.com.cn/*",
        "*://*.luogu.com/*",
        "*://*.nowcoder.com/*",
        "*://*.acwing.com/*",
        "*://*.codingninjas.com/*",
        "*://*.neetcode.io/*",
        "*://*.dailycodingproblem.com/*",
        "*://*.codility.com/*",
        "*://*.codesignal.com/*",
        "*://*.kattis.com/*",
        "*://*.open.kattis.com/*",
        "*://*.usaco.org/*",
        "*://*.codehs.com/*",
        "*://*.code.org/*",
        "*://*.khanacademy.org/*",
        "*://*.coursera.org/*",
        "*://*.udacity.com/*",
        "*://*.edx.org/*",
        "*://*.udemy.com/*",
        "*://*.dev.to/*",
        "*://*.hashnode.com/*",
        "*://*.hashnode.dev/*",
        "*://*.showwcase.com/*",
        "*://*.indiehackers.com/*",
        "*://*.ycombinator.com/*",
        "*://*.lobste.rs/*"
      ],
      "js": [
        "content/companion.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/leetcode/data.json",
        "content/leetcode/ratings.json"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    },
    {
      "resources": [
        "styles/codeforces/codeforces-themes.css"
      ],
      "matches": [
        "https://codeforces.com/*",
        "https://*.codeforces.com/*"
      ]
    },
    {
      "resources": [
        "styles/companion.css"
      ],
      "matches": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "https://getsprint.me/*",
        "https://*.getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "*://*.github.com/*",
        "*://*.github.io/*",
        "*://*.gitlab.com/*",
        "*://*.bitbucket.org/*",
        "*://*.gitee.com/*",
        "*://*.codeforces.com/*",
        "*://*.codeforces.ru/*",
        "*://*.atcoder.jp/*",
        "*://*.codechef.com/*",
        "*://*.hackerearth.com/*",
        "*://*.hackerrank.com/*",
        "*://*.topcoder.com/*",
        "*://*.geeksforgeeks.org/*",
        "*://*.stackoverflow.com/*",
        "*://*.stackexchange.com/*",
        "*://*.codewars.com/*",
        "*://*.coderbyte.com/*",
        "*://*.projecteuler.net/*",
        "*://*.spoj.com/*",
        "*://*.vjudge.net/*",
        "*://*.dmoj.ca/*",
        "*://*.oj.uz/*",
        "*://*.replit.com/*",
        "*://*.replit.co/*",
        "*://*.repl.it/*",
        "*://*.glot.io/*",
        "*://*.ideone.com/*",
        "*://*.jdoodle.com/*",
        "*://*.onlinegdb.com/*",
        "*://*.codepen.io/*",
        "*://*.jsfiddle.net/*",
        "*://*.scrimba.com/*",
        "*://*.freecodecamp.org/*",
        "*://*.w3schools.com/*",
        "*://*.programiz.com/*",
        "*://*.codecademy.com/*",
        "*://*.apnacollege.in/*",
        "*://*.apnacollege.com/*",
        "*://*.interviewbit.com/*",
        "*://*.lintcode.com/*",
        "*://*.algoexpert.io/*",
        "*://*.exercism.org/*",
        "*://*.exercism.io/*",
        "*://*.cses.fi/*",
        "*://*.hackerone.com/*",
        "*://*.luogu.com.cn/*",
        "*://*.luogu.com/*",
        "*://*.nowcoder.com/*",
        "*://*.acwing.com/*",
        "*://*.codingninjas.com/*",
        "*://*.neetcode.io/*",
        "*://*.dailycodingproblem.com/*",
        "*://*.codility.com/*",
        "*://*.codesignal.com/*",
        "*://*.kattis.com/*",
        "*://*.open.kattis.com/*",
        "*://*.usaco.org/*",
        "*://*.codehs.com/*",
        "*://*.code.org/*",
        "*://*.khanacademy.org/*",
        "*://*.coursera.org/*",
        "*://*.udacity.com/*",
        "*://*.edx.org/*",
        "*://*.udemy.com/*",
        "*://*.dev.to/*",
        "*://*.hashnode.com/*",
        "*://*.hashnode.dev/*",
        "*://*.showwcase.com/*",
        "*://*.indiehackers.com/*",
        "*://*.ycombinator.com/*",
        "*://*.lobste.rs/*"
      ]
    }
  ],
  "commands": {
    "analyze-complexity": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Analyze Time/Space Complexity of selected code"
    },
    "analyze-bug": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Debug selected code logic"
    },
    "toggle-chat": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Alt+Q"
      },
      "description": "Toggle SprintAI Chat Box"
    }
  }
}