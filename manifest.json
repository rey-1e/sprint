{
  "manifest_version": 3,
  "name": "LeetCode Company Tags",
  "version": "1.0",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Company Tags"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "web_accessible_resources": [
    {
      "resources": ["data.json"],
      "matches": ["<all_urls>"]
    }
  ]
}