{
  "manifest_version": 3,
  "name": "LeetCode Super-tools",
  "version": "1.1",
  "description": "Shows company tags and analyzes code complexity on LeetCode.",

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LeetCode Super-tools"
  },
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://leetcode.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data.json"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}