{
  "manifest_version": 3,
  "name": "CodeSprint - AI Companion for Programmers",
  "version": "3.2.3",
  "description": "Site-Specific Customizations, Analyze complexities, AI Debugging, AI Assistant Tailored for Programmers",
  "icons": {
    "128": "icon.png",
    "192": "icon.png",
    "512": "icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Sprint Assistant"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "https://getsprint.me/*",
        "https://*.getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content/leetcode-start.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/content-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/leetcode-idle.js"
      ],
      "css": [
        "styles/leetcode.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/companion.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data.json",
        "ratings.json"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    },
    {
      "resources": [
        "styles/companion.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "analyze-complexity": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Analyze Time/Space Complexity of selected code"
    },
    "analyze-bug": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Debug selected code logic"
    },
    "toggle-chat": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Alt+Q"
      },
      "description": "Toggle SprintAI Chat Box"
    }
  }
}