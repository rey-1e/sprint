{
  "manifest_version": 3,
  "name": "leetCode Sprint",
  "version": "1.0",
  "description": "Company-tags, Reviews, Complexity",
  "icons": {
      "128": "icon.png",
      "192": "icon.png",
      "512": "icon.png"
    },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LeetCode Super-tools"
  },
  "permissions": ["storage", "contextMenus"],
  "host_permissions":[
    "https://leetcode.com/*",
    "https://*.a.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches":[
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data.json"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}