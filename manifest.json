{
  "manifest_version": 3,
  "name": "CodeSprint - AI Companion for Programmers",
  "version": "3.2.3",
  "description": "Site-Specific Customizations, Analyze complexities, AI Debugging, AI Assistant Tailored for Programmers",
  "icons": {
    "128": "icon.png",
    "192": "icon.png",
    "512": "icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Sprint Assistant"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://us-central1-sprint-87863.cloudfunctions.net/*",
    "https://*.a.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "https://getsprint.me/*",
        "https://*.getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content/leetcode-start.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/content-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content/leetcode-idle.js"
      ],
      "css": [
        "styles/leetcode.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://leetcode.com/*",
        "https://*.leetcode.com/*",
        "https://leetcode.cn/*",
        "https://*.leetcode.cn/*",
        "https://getsprint.me/*",
        "https://*.getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://github.com/*",
        "https://*.github.com/*",
        "https://gitlab.com/*",
        "https://*.gitlab.com/*",
        "https://stackoverflow.com/*",
        "https://*.stackoverflow.com/*",
        "https://stackexchange.com/*",
        "https://*.stackexchange.com/*",
        "https://codeforces.com/*",
        "https://*.codeforces.com/*",
        "https://geeksforgeeks.org/*",
        "https://*.geeksforgeeks.org/*",
        "https://hackerrank.com/*",
        "https://*.hackerrank.com/*",
        "https://codecademy.com/*",
        "https://*.codecademy.com/*",
        "https://freecodecamp.org/*",
        "https://*.freecodecamp.org/*",
        "https://w3schools.com/*",
        "https://*.w3schools.com/*",
        "https://developer.mozilla.org/*",
        "https://*.developer.mozilla.org/*",
        "https://neetcode.io/*",
        "https://*.neetcode.io/*",
        "https://codechef.com/*",
        "https://*.codechef.com/*",
        "https://atcoder.jp/*",
        "https://*.atcoder.jp/*",
        "https://spoj.com/*",
        "https://*.spoj.com/*",
        "https://topcoder.com/*",
        "https://*.topcoder.com/*",
        "https://codewars.com/*",
        "https://*.codewars.com/*",
        "https://hackerearth.com/*",
        "https://*.hackerearth.com/*",
        "https://projecteuler.net/*",
        "https://*.projecteuler.net/*",
        "https://exercism.org/*",
        "https://*.exercism.org/*",
        "https://exercism.io/*",
        "https://*.exercism.io/*",
        "https://kattis.com/*",
        "https://*.kattis.com/*",
        "https://coderbyte.com/*",
        "https://*.coderbyte.com/*",
        "https://dev.to/*",
        "https://*.dev.to/*",
        "https://hashnode.com/*",
        "https://*.hashnode.com/*",
        "https://scrimba.com/*",
        "https://*.scrimba.com/*",
        "https://educative.io/*",
        "https://*.educative.io/*",
        "https://frontendmentor.io/*",
        "https://*.frontendmentor.io/*",
        "https://codepen.io/*",
        "https://*.codepen.io/*",
        "https://jsfiddle.net/*",
        "https://*.jsfiddle.net/*",
        "https://replit.com/*",
        "https://*.replit.com/*",
        "https://stackblitz.com/*",
        "https://*.stackblitz.com/*",
        "https://codesandbox.io/*",
        "https://*.codesandbox.io/*",
        "https://programiz.com/*",
        "https://*.programiz.com/*",
        "https://tutorialspoint.com/*",
        "https://*.tutorialspoint.com/*"
      ],
      "js": [
        "content/companion.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data.json",
        "ratings.json"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    },
    {
      "resources": [
        "styles/companion.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "analyze-complexity": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Analyze Time/Space Complexity of selected code"
    },
    "analyze-bug": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Debug selected code logic"
    },
    "toggle-chat": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Alt+Q"
      },
      "description": "Toggle SprintAI Chat Box"
    }
  }
}