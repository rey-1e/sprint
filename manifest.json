{
  "manifest_version": 3,
  "name": "LeetCode Sprint - The Premium Leetcode Extension",
  "version": "3.2",
  "description": "Company-tags, Reviews, Complexities, Elo ratings, AI Debugging, and Custom Themes.",
  "icons": {
    "128": "icon.png",
    "192": "icon.png",
    "512": "icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LeetCode Super-tools"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://leetcode.cn/*",
    "https://*.a.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "https://getsprint.me/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "theme-content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/submissions/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data.json",
        "ratings.json"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    }
  ],
  "commands": {
    "analyze-complexity": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Analyze Time/Space Complexity"
    },
    "analyze-bug": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "Toggle Where Am I Wrong Analysis"
    }
  }
}