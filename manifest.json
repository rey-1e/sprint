{
  "manifest_version": 3,
  "name": "LeetCode Debugger",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data.json"],
      "matches": ["*://leetcode.com/*"]
    }
  ]
}